{
  "expo": {
    "name": "Tambola Number Caller (Housie)",
    "slug": "tambola-number-caller",
    "version": "1.5.8",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "tambolanumbercaller",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.geekypajis.tambolanumbers",
      "buildNumber": "11",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads and improve the app experience.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/images/logo.png",
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-1373723692607134~5045643159"
      },
      "appleTeamId": "V8734DA44D",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "versionCode": 11,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo.png"
      },
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-1373723692607134~4420249362"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.geekypajis.tambolanumbers",
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1373723692607134~4420249362",
          "iosAppId": "ca-app-pub-1373723692607134~5045643159"
        }
      ],
      "expo-tracking-transparency",
      [
        "@react-native-firebase/app",
        {
          "ios": {
            "googleServicesFile": "./GoogleService-Info.plist"
          },
          "android": {
            "googleServicesFile": "./google-services.json"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af5a5714-a772-4c71-b483-b00466fe9989"
      }
    }
  }
}