{
  "expo": {
    "name": "Tambola Number Caller (Housie)",
    "slug": "tambola-number-caller",
    "version": "1.5.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tambolanumbercaller",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.geekypajis.tambolanumbers"
    },
    "android": {
      "androidAppId": "com.geekypajis.tambolanumbers",
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo.png"
      },
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-1373723692607134~4420249362"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.geekypajis.tambolanumbers"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1373723692607134~4420249362",
          "iosAppId": "ca-app-pub-1373723692607134~4420249362"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af5a5714-a772-4c71-b483-b00466fe9989"
      }
    }
  }
}